{"type":"tool_use","timestamp":"2026-03-23T03:41:52.599Z","tool_name":"write_file","tool_id":"write_file_1774237312599_0","parameters":{"content":"from typing import Dict, List, Optional\nfrom datasets import load_from_disk\nfrom .base import DatasetHandler\n\nclass GSM8KHuggingFaceHandler(DatasetHandler):\n    name = \"gsm8k_hf\"\n    default_train_path = \"datasets/gsm8k\"\n    default_test_path = \"datasets/gsm8k\"\n    default_max_tokens = 512\n\n    def __init__(self):\n        # We need to import the reward score from the original RandOpt\n        import os\n        import sys\n        # The reward score is in utils/reward_score\n        from utils.reward_score import gsm8k as gsm8k_reward\n        self.reward_module = gsm8k_reward\n\n    def load_data(self, path: str, split: str = \"train\", max_samples: Optional[int] = None) -> List[Dict]:\n        ds = load_from_disk(path)\n        data = ds[split]\n        if max_samples:\n            data = data.select(range(min(len(data), max_samples)))\n        \n        task_datas = []\n        for row in data:\n            # Format as messages for the Instruct model\n            task_datas.append({\n                \"messages\": [{\"role\": \"user\", \"content\": row[\"question\"]}],\n                \"ground_truth\": row[\"answer\"].split(\"####\")[-1].strip(),\n            })\n        return task_datas\n\n    def compute_reward(self, response: str, ground_truth: str) -> float:\n        reward = self.reward_module.compute_score(response, ground_truth, method=\"strict\")\n        if reward == 0:\n            reward = self.reward_module.compute_score(response, ground_truth, method=\"flexible\")\n        return float(reward)\n\n    def extract_answer(self, response: str) -> str:\n        answer = self.reward_module.extract_solution(response, method=\"strict\")\n        if answer is None:\n            answer = self.reward_module.extract_solution(response, method=\"flexible\")\n        return answer if answer is not None else \"\"\n\n    def format_answer_for_check(self, answer: str) -> str:\n        return f\"#### {answer}\"\n","file_path":"code/RandOpt/data_handlers/gsm8k_hf.py"}}

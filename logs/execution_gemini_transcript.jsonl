    print(f\"| {label} | {base_scores[i]:.1f}% | {std_scores[i]:.1f}% | {anti_scores[i]:.1f}% |\")\n\nif __name__ == \"__main__\":\n    main()\n","file_path":"src/analyze_results.py"}}

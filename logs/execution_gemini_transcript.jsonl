{"type":"tool_use","timestamp":"2026-03-23T03:36:59.376Z","tool_name":"replace","tool_id":"replace_1774237019376_0","parameters":{"old_string":"def run_sampling(args, engines, handler, train_prompts, train_datas, sampling_params):\n    \"\"\"Run perturbation sampling.\"\"\"\n    print(f\"\\n{'='*60}\\nPERTURBATION SAMPLING\\n{'='*60}\")\n    print(f\"Budget: {args.population_size} | Sigmas: {args.sigma_list}\")\n    \n    rng = np.random.default_rng(seed=args.global_seed)\n    perf: Dict[Tuple[int, float], float] = {}\n    \n    # Pre-generate unique seeds and sigmas\n    all_seeds = rng.choice(2**31, size=args.population_size, replace=False).tolist()\n    all_sigmas = rng.choice(args.sigma_list, size=args.population_size).tolist()\n    seed_idx = 0\n    \n    samples_evaluated, batch_idx = 0, 0\n    \n    while samples_evaluated < args.population_size:\n        batch_size = min(args.num_engines, args.population_size - samples_evaluated)\n        batch = [(all_seeds[seed_idx + i], all_sigmas[seed_idx + i]) for i in range(batch_size)]\n        seed_idx += batch_size\n        \n        # Evaluate batch\n        ray.get([engines[i].collective_rpc.remote(\"perturb_self_weights\", args=(int(s), sig, False)) \n                 for i, (s, sig) in enumerate(batch)])\n        \n        outputs = ray.get([engines[i].generate.remote(train_prompts, sampling_params, use_tqdm=False) \n                          for i in range(len(batch))])\n        \n        ray.get([engines[i].collective_rpc.remote(\"restore_self_weights\", args=(int(s), sig, False)) \n                 for i, (s, sig) in enumerate(batch)])\n        \n        # Process results\n        rewards = []\n        for i, (seed, sigma) in enumerate(batch):\n            r = handler.postprocess_outputs(outputs[i], train_datas)\n            perf[(seed, sigma)] = r\n            rewards.append(r)\n        \n        samples_evaluated += len(batch)\n        batch_idx += 1\n        print(f\"  Batch {batch_idx} | {samples_evaluated}/{args.population_size} | {['%.3f' % r for r in rewards]}\")\n    \n    print(f\"\\nSampling done.\")\n    \n    # Summary\n    print(f\"\\n{'='*60}\\nSAMPLING COMPLETE\\n{'='*60}\")\n    \n    # Calculate sigma stats\n    sigma_rewards: Dict[float, List[float]] = {s: [] for s in args.sigma_list}\n    for (seed, sigma), reward in perf.items():\n        sigma_rewards[sigma].append(reward)\n    \n    for sigma in args.sigma_list:\n        rewards_list = sigma_rewards[sigma]\n        if rewards_list:\n            print(f\"  σ={sigma}: mean={np.mean(rewards_list):.4f}, n={len(rewards_list)}\")\n    \n    # Find best sigma\n    best_sigma = max(args.sigma_list, key=lambda s: np.mean(sigma_rewards[s]) if sigma_rewards[s] else 0)\n    print(f\"\\n★ Best sigma: {best_sigma}\")\n    \n    return perf, best_sigma\n","file_path":"src/robust_randopt.py","new_string":"def run_sampling(args, engines, handler, train_prompts, train_datas, sampling_params):\n    \"\"\"Run perturbation sampling with various methods.\"\"\"\n    print(f\"\\n{'='*60}\\nPERTURBATION SAMPLING (Method: {args.method})\\n{'='*60}\")\n    print(f\"Budget: {args.population_size} | Sigmas: {args.sigma_list}\")\n    \n    rng = np.random.default_rng(seed=args.global_seed)\n    perf: Dict[Tuple[int, float, bool], float] = {}\n    \n    # Pre-generate unique seeds and sigmas\n    if args.method == \"antithetic\":\n        # Divide population size by 2 for pairs\n        effective_pop = args.population_size // 2\n        all_seeds = rng.choice(2**31, size=effective_pop, replace=False).tolist()\n        all_sigmas = rng.choice(args.sigma_list, size=effective_pop).tolist()\n        # Each seed gets both + and - versions\n        all_runs = []\n        for s, sig in zip(all_seeds, all_sigmas):\n            all_runs.append((s, sig, False))\n            all_runs.append((s, sig, True))\n    else:\n        # standard or orthogonal\n        all_seeds = rng.choice(2**31, size=args.population_size, replace=False).tolist()\n        all_sigmas = rng.choice(args.sigma_list, size=args.population_size).tolist()\n        all_runs = [(s, sig, False) for s, sig in zip(all_seeds, all_sigmas)]\n    \n    samples_evaluated, batch_idx = 0, 0\n    \n    while samples_evaluated < len(all_runs):\n        batch_size = min(args.num_engines, len(all_runs) - samples_evaluated)\n        batch = all_runs[samples_evaluated:samples_evaluated + batch_size]\n        \n        # Evaluate batch\n        ray.get([engines[i].collective_rpc.remote(\"perturb_self_weights\", args=(int(s), sig, neg)) \n                 for i, (s, sig, neg) in enumerate(batch)])\n        \n        outputs = ray.get([engines[i].generate.remote(train_prompts, sampling_params, use_tqdm=False) \n                          for i in range(len(batch))])\n        \n        ray.get([engines[i].collective_rpc.remote(\"restore_self_weights\", args=(int(s), sig, neg)) \n                 for i, (s, sig, neg) in enumerate(batch)])\n        \n        # Process results\n        rewards = []\n        for i, (seed, sigma, neg) in enumerate(batch):\n            r = handler.postprocess_outputs(outputs[i], train_datas)\n            perf[(seed, sigma, neg)] = r\n            rewards.append(r)\n        \n        samples_evaluated += len(batch)\n        batch_idx += 1\n        print(f\"  Batch {batch_idx} | {samples_evaluated}/{len(all_runs)} | {['%.3f' % r for r in rewards]}\")\n    \n    print(f\"\\nSampling done.\")\n    \n    # Summary\n    print(f\"\\n{'='*60}\\nSAMPLING COMPLETE\\n{'='*60}\")\n    \n    # Calculate sigma stats\n    sigma_rewards: Dict[float, List[float]] = {s: [] for s in args.sigma_list}\n    for (seed, sigma, neg), reward in perf.items():\n        sigma_rewards[sigma].append(reward)\n    \n    for sigma in args.sigma_list:\n        rewards_list = sigma_rewards[sigma]\n        if rewards_list:\n            print(f\"  σ={sigma}: mean={np.mean(rewards_list):.4f}, n={len(rewards_list)}\")\n    \n    # Find best sigma\n    best_sigma = max(args.sigma_list, key=lambda s: np.mean(sigma_rewards[s]) if sigma_rewards[s] else 0)\n    print(f\"\\n★ Best sigma: {best_sigma}\")\n    \n    return perf, best_sigma\n","instruction":"Implement antithetic and orthogonal sampling in run_sampling."}}
